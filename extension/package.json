{
  "name": "intellicode-fabric",
  "displayName": "IntelliCode Fabric",
  "description": "AI-powered code assistant with RAG, multi-agent system, local LLM inference, and fine-tuning — fully local, fully private",
  "version": "1.0.0",
  "publisher": "intellicode-fabric",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Programming Languages", "Machine Learning", "Other"],
  "keywords": ["ai", "code", "assistant", "rag", "llm", "copilot"],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "intellicode-fabric",
          "title": "IntelliCode Fabric",
          "icon": "$(hubot)"
        }
      ]
    },
    "views": {
      "intellicode-fabric": [
        {
          "type": "webview",
          "id": "intelliCodeFabric.sidebar",
          "name": "IntelliCode Fabric"
        }
      ]
    },
    "commands": [
      { "command": "intelliCodeFabric.startServer", "title": "IntelliCode Fabric: Start Backend Server" },
      { "command": "intelliCodeFabric.indexProject", "title": "IntelliCode Fabric: Index Current Project" },
      { "command": "intelliCodeFabric.chat", "title": "IntelliCode Fabric: Open Chat" },
      { "command": "intelliCodeFabric.generateCode", "title": "IntelliCode Fabric: Generate Code" },
      { "command": "intelliCodeFabric.refactorCode", "title": "IntelliCode Fabric: Refactor Selected Code" },
      { "command": "intelliCodeFabric.generateTests", "title": "IntelliCode Fabric: Generate Tests" },
      { "command": "intelliCodeFabric.explainCode", "title": "IntelliCode Fabric: Explain Selected Code" },
      { "command": "intelliCodeFabric.inlineEdit", "title": "IntelliCode Fabric: Inline Edit" },
      { "command": "intelliCodeFabric.selectModel", "title": "IntelliCode Fabric: Select Model" },
      { "command": "intelliCodeFabric.downloadModel", "title": "IntelliCode Fabric: Download Model" },
      { "command": "intelliCodeFabric.fineTune", "title": "IntelliCode Fabric: Fine-tune on Project" }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "intelliCodeFabric.explainCode",
          "when": "editorHasSelection",
          "group": "intellicode-fabric@1"
        },
        {
          "command": "intelliCodeFabric.refactorCode",
          "when": "editorHasSelection",
          "group": "intellicode-fabric@2"
        },
        {
          "command": "intelliCodeFabric.generateTests",
          "when": "editorHasSelection",
          "group": "intellicode-fabric@3"
        },
        {
          "command": "intelliCodeFabric.inlineEdit",
          "when": "editorHasSelection",
          "group": "intellicode-fabric@4"
        }
      ]
    },
    "keybindings": [
      {
        "command": "intelliCodeFabric.chat",
        "key": "ctrl+shift+a",
        "mac": "cmd+shift+a"
      },
      {
        "command": "intelliCodeFabric.inlineEdit",
        "key": "ctrl+shift+e",
        "mac": "cmd+shift+e",
        "when": "editorHasSelection"
      },
      {
        "command": "intelliCodeFabric.generateCode",
        "key": "ctrl+shift+g",
        "mac": "cmd+shift+g"
      }
    ],
    "configuration": {
      "title": "IntelliCode Fabric",
      "properties": {
        "intelliCodeFabric.serverUrl": {
          "type": "string",
          "default": "http://127.0.0.1:8765",
          "description": "Backend server URL"
        },
        "intelliCodeFabric.autoIndex": {
          "type": "boolean",
          "default": true,
          "description": "Automatically index project on startup"
        },
        "intelliCodeFabric.pythonPath": {
          "type": "string",
          "default": "python",
          "description": "Path to Python interpreter"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "webpack --mode production",
    "watch": "webpack --mode development --watch",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.54.0",
    "ts-loader": "^9.5.1",
    "typescript": "^5.3.2",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "node-fetch": "^2.7.0",
    "ws": "^8.16.0"
  }
}